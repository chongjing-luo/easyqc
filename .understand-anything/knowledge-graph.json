{
  "version": "1.0.0",
  "project": {
    "name": "EasyQC",
    "description": "EasyQC 是一个专业的医学影像质量控制工具，专为神经影像研究设计，支持多种医学影像格式的质量评估和评分。提供基于 tkinter 的图形用户界面，用于多项目、多评分者的目视检查和打分工-作流。",
    "languages": ["python", "shell", "markdown"],
    "frameworks": ["tkinter"],
    "analyzedAt": "2026-06-01T13:00:00Z",
