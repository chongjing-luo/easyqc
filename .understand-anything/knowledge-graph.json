  },
  "nodes": [
    {
      "id": "file:easyqc.py",
      "type": "file",
      "name": "easyqc.py",
      "filePath": "easyqc.py",
      "summary": "主程序入口。解析命令行参数，支持GUI模式（默认）和CLI模式（传入四个参数 project module rater ezqcid 直接打开QC页面）。负责路径初始化、日志系统导入、以及 tkinter 主循环的启动。",
      "tags": ["入口点", "cli", "应用启动"],
      "complexity": "moderate"
    },
    {
      "id": "file:gui/main_window.py",
      "type": "file",
      "name": "main_window.py",
      "filePath": "gui/main_window.py",
      "summary": "EasyQCApp 主窗口类。包含整个GUI的构建逻辑：项目管理下拉框、常量设置面板、变量设置面板、以及可滚动的QC模块卡片区域。每个模块卡片包含展开/收起、评分(score)和标签(tag)的动态配置、评分人设置、子进程控制、代码编辑等完整功能。初始化时创建 DataManager、FileUtils、ProjectManager、DialogMain 和 TableDisplay，形成组件依赖网。",
      "tags": ["主窗口", "GUI", "tkinter", "模块管理", "卡片布局"],
      "complexity": "complex"
    },
    {
      "id": "file:gui/dialog_main.py",
      "type": "file",
      "name": "dialog_main.py",
      "filePath": "gui/dialog_main.py",
      "summary": "DialogMain 对话框功能类。实现所有模态操作：创建/导入/移除项目、添加/编辑常量、浏览文件夹和文件、设置变量(三种方法：路径导入、文件导入、文本输入)、合并新数据、添加/删除/管理模块、分数验证(支持范围'3-5'、列表'1,3,5'、比较'>3'、等式'=3')、模块导入导出、开始质控等。",
      "tags": ["对话框", "项目管理", "变量设置", "模块管理", "分数验证"],
      "complexity": "complex"
    },
    {
      "id": "file:gui/gui_qcpage.py",
      "type": "file",
      "name": "gui_qcpage.py",
      "filePath": "gui/gui_qcpage.py",
      "summary": "gui_qcpage QC页面类。管理单个被试的质控评分界面：加载被试数据、执行自定义Python代码(通过子进程或eval)、渲染tags和scores的交互控件(键盘快捷键支持)、保存评分到JSON文件、支持自动/手动切换被试、监听模式(watch_mode)自动刷新。每个评分文件命名为 '{module}._.{ezqcid}._.{rater}.json'。",
      "tags": ["QC页面", "评分界面", "键盘控制", "子进程", "被试管理"],
      "complexity": "complex"
    },
    {
      "id": "file:gui/gui_table.py",
      "type": "file",
      "name": "gui_table.py",
      "filePath": "gui/gui_table.py",
      "summary": "TableDisplay 表格显示类。提供DataFrame的可视化展示和SQL过滤排序功能。通过 pandasql 对数据执行 SQL 查询实现筛选，支持所有模块的数据表格和变量表格的展示。包含过滤界面、排序功能和数据导出。",
      "tags": ["表格显示", "SQL过滤", "pandasql", "数据可视化"],
      "complexity": "moderate"
    },
    {
      "id": "file:utils/projects_manager.py",
      "type": "file",
      "name": "projects_manager.py",
      "filePath": "utils/projects_manager.py",
      "summary": "ProjectManager 项目管理核心。管理项目CRUD操作、设置持久化(settings JSON)、模块管理(add_key插队逻辑和重新索引)、评分文件加载和聚合。load_ratings()扫描所有 RatingFiles 目录下的JSON文件，验证文件名-目录-内容一致性，通过pivot_table构建宽格式评分汇总表，合并到 ezqc_all 主表中。DataContainer 内部类持有所有可变状态。",
      "tags": ["项目管理", "数据聚合", "评分加载", "pivot", "状态管理", "JSON持久化"],
      "complexity": "complex"
    },
    {
      "id": "file:utils/data_manager.py",
      "type": "file",
      "name": "data_manager.py",
      "filePath": "utils/data_manager.py",
      "summary": "DataManager 数据管理器。处理所有数据I/O操作：目录列表提取、多格式文件读取(CSV/Excel/TXT/list)、文本解析为DataFrame、变量名和批次设置、以及核心的SQL过滤排序引擎 select_filter_sorter()。通过 pandasql 对DataFrame执行SQL查询，支持 _othervar_ 占位符自动展开为所有未指定列。",
      "tags": ["数据管理", "文件读取", "SQL引擎", "pandasql", "文本解析"],
      "complexity": "moderate"
    },
    {
